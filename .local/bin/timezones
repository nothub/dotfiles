#!/usr/bin/env sh

set -eu

tzdate() {
    printf "%-5s %-9s %s\n" \
        "$(TZ="$1" date "+%Z")" \
        "$(TZ="$1" date "+%H:%M:%S")" \
        "$1"
}

tzdate "America/Los_Angeles"
tzdate "America/Chicago"
tzdate "America/New_York"
tzdate "Europe/London"
tzdate "Europe/Berlin"
tzdate "Asia/Jerusalem"
tzdate "Europe/Moscow"
tzdate "Australia/Perth"
tzdate "Asia/Tokyo"
tzdate "Australia/Sydney"
