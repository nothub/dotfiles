{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "semanticCommits": "enabled",
  "minimumReleaseAge": "7 days",
  "configMigration": true,
  "timezone": "Europe/Berlin",
  "packageRules": [
    {
      "description": "No minimumReleaseAge delay",
      "matchDatasources": [
        "github-tags"
      ],
      "matchDepNames": [
        "nothub/**"
      ],
      "minimumReleaseAge": "0 days"
    },
    {
      "description": "No minimumReleaseAge delay",
      "matchDatasources": [
        "forgejo-tags"
      ],
      "registryUrls": [
        "https://codeberg.org"
      ],
      "matchDepNames": [
        "fhuebner/**"
      ],
      "minimumReleaseAge": "0 days"
    }
  ]
}
