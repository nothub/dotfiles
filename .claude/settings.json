{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/tracker/track-usage.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/tracker/post-edit.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "mcp__aikb__note_search",
      "mcp__aikb__note_read",
      "mcp__aikb__note_list",
      "mcp__aikb__note_backlinks"
    ]
  },
  "outputStyle": "Grug-Brained",
  "language": "english",
  "feedbackSurveyRate": 0,
  "skillListingBudgetFraction": 0.03,
  "effortLevel": "auto",
  "theme": "dark-ansi",
  "editorMode": "normal",
  "preferredNotifChannel": "kitty",
  "autoCompactEnabled": false
}
